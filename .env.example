# === 必需 ===
DATABASE_URL=./data/jobs.db

# === 可选：Reed API ===
# 从 https://www.reed.co.uk/developers 申请
REED_API_KEY=

# === 可选：Webshare 代理池 ===
# 从 https://www.webshare.io 获取
WEBSHARE_API_KEY=
# 列表 API mode：住宅池常用 backbone；数据中心常用 direct（见 Webshare API 文档）
# WEBSHARE_PROXY_LIST_MODE=backbone

# Jooble /desc/ 仅解析雇主链、省代理带宽：拦截图片/CSS/字体，整页 HTML 不传 Node（设 1 开启）
# JOOBLE_DESC_MINIMAL_BANDWIDTH=1
# CF 并发探测默认省带宽（设 0 则拉整页 HTML 做 body CF 启发式）
# CF_PROBE_MINIMAL_BANDWIDTH=

# === 可选：LinkedIn ===
# 从浏览器 DevTools → Application → Cookies 获取 li_at 值
LINKEDIN_COOKIE=

# === 可选：Jooble API ===
# 从 https://jooble.org/api/about 申请 (现在可选，CDP 模式不需要)
JOOBLE_API_KEY=

# === 服务器配置 ===
PORT=3000
BROWSER_HEADLESS=true
