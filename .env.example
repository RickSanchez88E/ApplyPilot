# === 必需 ===
DATABASE_URL=postgres://orchestrator:orchestrator@localhost:5433/job_orchestrator

# === Redis (BullMQ 队列) ===
REDIS_URL=redis://localhost:6380

# === 可选：Reed API ===
# 从 https://www.reed.co.uk/developers 申请
REED_API_KEY=

# === 可选：Webshare 代理池 ===
# 从 https://www.webshare.io 获取
WEBSHARE_API_KEY=
# WEBSHARE_PROXY_LIST_MODE=backbone

# Jooble /desc/ 省代理带宽
# JOOBLE_DESC_MINIMAL_BANDWIDTH=1
# CF_PROBE_MINIMAL_BANDWIDTH=

# === 可选：LinkedIn ===
LINKEDIN_COOKIE=

# === 可选：Jooble API ===
JOOBLE_API_KEY=

# === 服务器配置 ===
PORT=3000
BROWSER_HEADLESS=true

# === 本地持久化浏览器配置 (宿主机模式) ===
# 浏览器引擎: chrome | edge
LOCAL_BROWSER_ENGINE=edge
# 引擎可执行文件路径（不设置时按 engine 使用默认路径）
LOCAL_BROWSER_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# 引擎 user data 根目录（不设置时按 engine 使用默认路径）
LOCAL_BROWSER_USER_DATA_DIR=C:\Users\rick\AppData\Local\Microsoft\Edge\User Data
# 自动化 profile 子目录名（建议与日常浏览 profile 分离，例如 sanchez）
LOCAL_BROWSER_PROFILE_DIRECTORY=sanchez
# 兼容旧字段（可选，建议迁移到 LOCAL_BROWSER_*）
# CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_USER_DATA_DIR=C:\Users\rick\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE_DIRECTORY=sanchez
# 自动化用的独立数据目录 (避免与正在运行的 Chrome 冲突)
# 首次启动时自动从真实 profile 同步登录态
LOCAL_BROWSER_DATA_DIR=.local-browser-data
# profile clone 刷新策略
# 0 = 每次启动都重同步；默认 4 小时
PROFILE_SYNC_TTL_MS=14400000
# true = 每次启动前强制重同步（成本更高，但登录态更新更及时）
PROFILE_RESYNC_BEFORE_LAUNCH=false
# 本地浏览器是否 headless (false = 可视窗口)
LOCAL_BROWSER_HEADLESS=true
# 空闲超时后关闭浏览器进程 (毫秒, 默认 5 分钟)
LOCAL_BROWSER_IDLE_TIMEOUT_MS=300000
# lease 心跳间隔（毫秒，默认 60000）
LEASE_HEARTBEAT_INTERVAL_MS=60000

# === 熔断器配置 ===
# 连续失败多少次触发熔断
BREAKER_MAX_FAILURES=3
# 熔断冷却时间 (毫秒, 默认 30 分钟)
BREAKER_COOLDOWN_MS=1800000

# === Jooble 本地慢速模式 ===
# 单轮最大详情页数
JOOBLE_DESC_HARD_CAP=20
# 页面间延迟 (毫秒)
JOOBLE_PAGE_DELAY_MIN_MS=5000
JOOBLE_PAGE_DELAY_MAX_MS=15000

# === Apply Discovery Backfill（调度语义） ===
# scheduler 每个 tick 的全局 dispatch 上限（不是单平台上限）
APPLY_BACKFILL_LIMIT=30
# backfill tick 间隔（毫秒）
APPLY_BACKFILL_INTERVAL_MS=600000
# 分平台 backfill 单 tick 上限，格式: source:limit,source:limit
# 默认策略：
#   jooble=3（慢速稳定），linkedin=4（受限并发），reed=1/remoteok=1（无登录态时低频探测），hn_hiring=8/devitjobs=8（轻链路高吞吐）
APPLY_BACKFILL_SOURCE_LIMITS=jooble:3,linkedin:4,reed:1,remoteok:1,hn_hiring:8,devitjobs:8
# 需要登录态的平台（登录相关状态进入 gated retry）
APPLY_LOGIN_REQUIRED_SOURCES=linkedin,reed,remoteok
# 当前“登录态可用”的平台（仅这些平台会重试 requires_login/oauth/requires_registration）
# 例：APPLY_LOGIN_READY_SOURCES=linkedin
APPLY_LOGIN_READY_SOURCES=

# === crawl_runs crash recovery ===
# 自动回收长时间 running 残留（分钟）
CRAWL_RUN_RECOVERY_TIMEOUT_MINUTES=180
# 回收策略：failed | cancelled
CRAWL_RUN_RECOVERY_STATUS=failed
# 回收扫描间隔（毫秒）
CRAWL_RUN_RECOVERY_INTERVAL_MS=900000
