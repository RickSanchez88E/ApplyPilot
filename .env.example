# ── PostgreSQL ──
DATABASE_URL=postgres://orchestrator:orchestrator@localhost:5432/job_orchestrator

# ── LinkedIn Authentication ──
# Export your browser's LinkedIn cookies:
#   li_at: main session token
#   JSESSIONID: AJAX CSRF token
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

# ── Search Config ──
SEARCH_KEYWORDS="software engineer,backend engineer,security engineer"
SEARCH_LOCATION="London, United Kingdom"
SEARCH_TIME_FILTER=r86400
SCRAPE_INTERVAL_MS=1800000

# ── Logging ──
LOG_LEVEL=info
NODE_ENV=development
